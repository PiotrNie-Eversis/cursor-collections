{
  "name": "eversis-docs-mcp-node",
  "version": "0.1.0",
  "private": true,
  "description": "Alternative Node.js MCP server for .docx chapter tools (JSZip + @xmldom/xmldom). Same tool names as mcp/eversis-docs-mcp (Python) — enable only one server in Cursor.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "npm run build && node --test dist/tests/chapters.test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xmldom/xmldom": "^0.9.8",
    "jszip": "^3.10.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "docx": "^9.5.0",
    "typescript": "^5.7.0"
  }
}
