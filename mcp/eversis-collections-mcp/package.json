{
  "name": "eversis-collections-mcp",
  "version": "1.0.0",
  "private": true,
  "description": "Local MCP server for cursor-collections: list, read, and validate eversis-* skills; run allowlisted repo and per-skill scripts. Not published to npm — build from the repository.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "eversis-collections": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx --test tests/chapters.test.ts",
    "validate": "node dist/cli.js validate"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xmldom/xmldom": "^0.9.8",
    "jszip": "^3.10.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "docx": "^9.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0"
  }
}